// Prisma schema for Fab Shopper

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum ProductStatus {
  PUBLISHED
  DRAFT
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  ABANDONED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum NotificationType {
  ORDER
  PAYMENT
  SYSTEM
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(STAFF)
  createdAt DateTime  @default(now())
}

model Product {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  shortDescription String?
  longDescription  String?
  productType      ProductType        @default(SIMPLE)
  images           String[]
  price            Decimal
  costPrice        Decimal?
  discountedPrice  Decimal?
  stockQuantity    Int                @default(0)
  unit             String?            @default("pc")
  barcode          String?
  status           ProductStatus      @default(DRAFT)
  collections      Collection[]       @relation("ProductCollections")
  variants         ProductVariant[]
  attributes       ProductAttribute[]
  orderItems       OrderItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ProductVariant {
  id            String   @id @default(cuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  size          String?
  color         String?
  material      String?
  fitType       String?
  stockQuantity Int      @default(0)
  price         Decimal?
  images        String[]
  sku           String?
  orderItems    OrderItem[]
}

model ProductAttribute {
  id          String  @id @default(cuid())
  product     Product @relation(fields: [productId], references: [id])
  productId   String
  sizes       String[]
  colors      String[]
  material    String?
  fitType     String?
  waistLength String?
  waistLine   String?
  jeanStyle   String?
  style       String?
  occasion    String?
  priceRange  String?
}

model Collection {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[] @relation("ProductCollections")
}

model Customer {
  id                     String    @id @default(cuid())
  firstName              String
  lastName               String
  email                  String?   @unique
  password               String?
  phone                  String?
  instagramHandle        String?
  additionalInfo         String?
  shippingAddressId      String?   @unique
  shippingAddress        Address?  @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId       String?   @unique
  billingAddress         Address?  @relation("BillingAddress", fields: [billingAddressId], references: [id])
  orders                 Order[]
  subscribedToNewsletter Boolean   @default(false)
  welcomeEmailSent       Boolean   @default(false)
  createdAt              DateTime  @default(now())
}

model Address {
  id              String   @id @default(cuid())
  address         String
  city            String?
  state           String?
  country         String   @default("Nigeria")
  zipCode         String?
  shippingCustomer Customer? @relation("ShippingAddress")
  billingCustomer  Customer? @relation("BillingAddress")
}

model Order {
  id               String         @id @default(cuid())
  orderNumber      String         @unique
  customer         Customer       @relation(fields: [customerId], references: [id])
  customerId       String
  items            OrderItem[]
  subtotal         Decimal
  shippingFee      Decimal        @default(0)
  vatAmount        Decimal        @default(0)
  total            Decimal
  status           OrderStatus    @default(PENDING)
  paymentStatus    PaymentStatus  @default(UNPAID)
  paymentMethod    String?
  paystackRef      String?
  shippingMethod   ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  shippingMethodId String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model OrderItem {
  id        String         @id @default(cuid())
  order     Order          @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product        @relation(fields: [productId], references: [id])
  productId String
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId String?
  quantity  Int
  price     Decimal
  size      String?
  color     String?
}

model ShippingMethod {
  id           String   @id @default(cuid())
  locationName String   @unique
  description  String?
  fee          Decimal  @default(0)
  isFree       Boolean  @default(false)
  isPickup     Boolean  @default(false)
  orders       Order[]
  createdAt    DateTime @default(now())
}

model Tax {
  id                   String   @id @default(cuid())
  name                 String   @unique
  description          String?
  percentage           Decimal
  applyToOfflineOrder  Boolean  @default(false)
  applyToWebCheckout   Boolean  @default(false)
  applyToPOS           Boolean  @default(false)
  createdAt            DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model StoreSettings {
  id              String  @id @default(cuid())
  businessName    String  @default("Fab Shopper")
  tagline         String?
  description     String?
  contactPhone    String?
  address         String?
  lowStockAlert   Int     @default(3)
  showOutOfStock  Boolean @default(true)
  showStockCount  Boolean @default(true)
  vatPercentage   Decimal @default(7.5)
  bankName        String?
  accountNumber   String?
  accountName     String?
  snapPixelId     String?
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model StoreVisit {
  id        String   @id @default(cuid())
  date      String   // Format: YYYY-MM-DD
  ipHash    String   // Hashed to maintain anonymity while allowing unique daily counts
  createdAt DateTime @default(now())

  @@unique([date, ipHash])
}
